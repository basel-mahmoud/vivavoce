{
  "expo": {
    "name": "VivaVoce",
    "slug": "vivavoce",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "vivavoce",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "app.basel.vivavoce",
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "VivaVoce records your spoken answers so it can transcribe them and give you coaching feedback. You can turn off audio retention at any time."
      }
    },
    "android": {
      "package": "app.basel.vivavoce",
      "permissions": ["RECORD_AUDIO"],
      "adaptiveIcon": {
        "backgroundColor": "#0C0A09",
        "foregroundImage": "./assets/adaptive-icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0C0A09",
          "image": "./assets/splash-icon.png",
          "imageWidth": 80
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": { "projectId": "00000000-0000-0000-0000-000000000000" }
    },
    "owner": "baselmahmoud"
  }
}
