{
  "expo": {
    "name": "VivaVoce",
    "slug": "vivavoce",
    "version": "1.6.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "vivavoce",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "app.basel.vivavoce",
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "VivaVoce records your spoken answers so it can transcribe them and give you coaching feedback. You can turn off audio retention at any time."
      }
    },
    "android": {
      "package": "app.basel.vivavoce",
      "permissions": [
        "RECORD_AUDIO",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#FF4D26",
        "foregroundImage": "./assets/adaptive-icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "allowBackup": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#161412",
          "image": "./assets/splash-icon.png",
          "imageWidth": 80
        }
      ],
      "expo-audio",
      "@react-native-community/datetimepicker",
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "cf7d1d33-f374-4d21-b05d-b74afbea1b50"
      }
    },
    "owner": "baselmahmoud"
  }
}
