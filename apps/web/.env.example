# ─── Database (Neon Postgres) ────────────────────────────────────────────────
# Pooled connection string for serverless runtime (used by the app).
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/vivavoce?sslmode=require"
# Direct (non-pooled) connection for migrations & seeds.
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/vivavoce?sslmode=require"
# Least-privilege application role used at runtime (see scripts/apply-rls.ts).
APP_DATABASE_URL="postgresql://vivavoce_app:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/vivavoce?sslmode=require"

# ─── Clerk (auth) ────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxx"
CLERK_SECRET_KEY="sk_test_xxx"
CLERK_WEBHOOK_SIGNING_SECRET="whsec_xxx"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# ─── Gemini (AI) ─────────────────────────────────────────────────────────────
GEMINI_API_KEY="your-google-ai-studio-key"
# Free-tier compatible default; override to swap models without code changes.
GEMINI_MODEL="gemini-2.0-flash"
GEMINI_TIMEOUT_MS="20000"

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Comma-separated origins allowed to call the mobile API (CORS). Empty = same-origin only.
MOBILE_ALLOWED_ORIGINS=""
# Secret shared with cron/worker endpoints for retention sweeps etc.
INTERNAL_JOB_SECRET="generate-a-long-random-string"
NODE_ENV="development"
